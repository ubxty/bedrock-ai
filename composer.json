{
    "name": "ubxty/bedrock-ai",
    "description": "A Laravel package for seamless AWS Bedrock integration with multi-key rotation, cross-region inference, usage tracking, pricing, and powerful CLI tools.",
    "keywords": ["aws", "bedrock", "ai", "laravel", "claude", "titan", "llama", "nova"],
    "license": "MIT",
    "version": "0.0.5",
    "type": "library",
    "authors": [
        {
            "name": "Ubxty",
            "email": "info.ubxty@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "aws/aws-sdk-php": "^3.300",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Ubxty\\BedrockAi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ubxty\\BedrockAi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ubxty\\BedrockAi\\BedrockAiServiceProvider"
            ],
            "aliases": {
                "Bedrock": "Ubxty\\BedrockAi\\Facades\\Bedrock"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
